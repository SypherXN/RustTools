{
  "name": "@rusttools/discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "node --env-file=../../.env ../../node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start": "node --env-file=../../.env dist/index.js",
    "register-commands": "node --env-file=../../.env ../../node_modules/tsx/dist/cli.mjs src/register-commands.ts"
  },
  "dependencies": {
    "@rusttools/shared": "*",
    "discord.js": "^14.26.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
