    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@rusttools/shared": "*",
    "better-sqlite3": "^11.9.1",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
