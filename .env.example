# =============================================================================
# RustTools — copy to .env and fill in values
# =============================================================================

# --- API ---
NODE_ENV=production
API_PORT=3000
API_HOST=0.0.0.0
API_PUBLIC_URL=https://rusttools.yourdomain.com
SESSION_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=change-me-32-byte-hex-or-base64-key-for-tokens

# Comma-separated origins allowed for CORS (your GitHub Pages URL)
CORS_ORIGINS=https://sypherxn.github.io,http://localhost:5173
# Where Discord OAuth redirects after login (GitHub Pages URL with repo path if applicable)
FRONTEND_URL=https://sypherxn.github.io/RustTools

# SQLite database path (inside Docker: /data/rusttools.db)
DATABASE_URL=file:./data/rusttools.db

# --- Discord OAuth (web login) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://rusttools.yourdomain.com/auth/discord/callback

# --- Discord Bot ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Comma-separated role IDs (optional — leave blank to allow all guild members)
DISCORD_ROLE_ADMIN=
DISCORD_ROLE_SWITCH=
DISCORD_ROLE_VIEW=
DISCORD_NOTIFICATION_CHANNEL_ID=
DISCORD_TEAM_CHAT_CHANNEL_ID=

# Shared secret for Discord bot → API internal routes
INTERNAL_API_KEY=change-me-internal-api-key

# --- Automations (optional) ---
AUTOMATION_NIGHT_LIGHTS=false
AUTOMATION_NIGHT_LIGHT_ENTITY_IDS=
AUTOMATION_TEAM_OFFLINE_SAM=false
AUTOMATION_SAM_SWITCH_ENTITY_ID=

# --- Rust+ FCM (pairing) ---
# Path to rustplus.js FCM config after running: npx @liamcottle/rustplus.js fcm-register
RUSTPLUS_FCM_CONFIG_PATH=./data/fcm-config.json

# --- Caddy (reverse proxy) ---
DOMAIN=rusttools.yourdomain.com
ACME_EMAIL=you@example.com
