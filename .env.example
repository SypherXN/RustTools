# =============================================================================
# RustTools — copy to .env and fill in values
# =============================================================================

# --- API ---
NODE_ENV=production
# Production: API validates SESSION_SECRET, ENCRYPTION_KEY, DISCORD_GUILD_ID,
# DISCORD_ROLE_* (at least one), INTERNAL_API_KEY (32+ chars), and rejects
# RUSTPLUS_ALLOW_UNPROMPTED_PAIR=true at startup.
# Run ./scripts/setup.sh — generates secrets + writes data/DEPLOY-REMINDERS.txt
# (includes GitHub Actions variable VITE_API_URL checklist).
API_PORT=3000
API_HOST=0.0.0.0
API_PUBLIC_URL=https://rusttools.yourdomain.com
SESSION_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=change-me-32-byte-hex-or-base64-key-for-tokens

# Comma-separated origins allowed for CORS (your GitHub Pages URL)
CORS_ORIGINS=https://sypherxn.github.io,http://localhost:5173
# Where Discord OAuth redirects after login (GitHub Pages URL with repo path if applicable)
FRONTEND_URL=https://sypherxn.github.io/RustTools

# SQLite database path (inside Docker: /data/rusttools.db)
DATABASE_URL=file:./data/rusttools.db
# Max API requests per IP per minute (default 600). /health is exempt.
# API_RATE_LIMIT_MAX=600

# Procgen .map parse child-process heap (MB). Default 4096 suits Oracle A1 (12 GB RAM).
# On E2.1.Micro (1 GB), use 2048 and add 2 GB swap — see docs/SETUP.md
# PROCGEN_PARSE_HEAP_MB=4096

# --- Discord OAuth (web login) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://rusttools.yourdomain.com/auth/discord/callback

# --- Discord Bot ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Comma-separated role IDs — required in production (NODE_ENV=production)
DISCORD_ROLE_ADMIN=
DISCORD_ROLE_SWITCH=
DISCORD_ROLE_VIEW=
DISCORD_NOTIFICATION_CHANNEL_ID=
# Optional dedicated channel for smart alarms; falls back to DISCORD_NOTIFICATION_CHANNEL_ID
# Can also be set in Discord with /channel set purpose:alarms
DISCORD_ALARM_CHANNEL_ID=
DISCORD_TEAM_CHAT_CHANNEL_ID=
# Optional separate channel for map event alerts (cargo, heli, chinook); falls back to notification channel
# Can also be set in Discord with /channel set purpose:events
DISCORD_EVENT_CHANNEL_ID=
# Optional dedicated channel for Deep Sea alerts; falls back to event/notification channel
DISCORD_DEEP_SEA_CHANNEL_ID=

# Shared secret for Discord bot → API internal routes (32+ chars in production; generate with: openssl rand -hex 32)
INTERNAL_API_KEY=change-me-to-a-32-plus-character-random-internal-api-key

# --- Automations (optional) ---
AUTOMATION_NIGHT_LIGHTS=false
AUTOMATION_NIGHT_LIGHT_ENTITY_IDS=
AUTOMATION_TEAM_OFFLINE_SAM=false
AUTOMATION_SAM_SWITCH_ENTITY_ID=
# Post when cargo / chinook / patrol heli spawn (map poll)
AUTOMATION_EVENT_TEAM_CHAT=false
# Deep Sea open/close alerts (offshore vending detection)
AUTOMATION_DEEP_SEA_TEAM_CHAT=false
AUTOMATION_DEEP_SEA_DISCORD=true
# Deep Sea timer defaults (seconds) — refine if your server uses custom deepsea.* convars
DEEPSEA_OPEN_DURATION_SECONDS=10800
DEEPSEA_COOLDOWN_MIN_SECONDS=5400
DEEPSEA_COOLDOWN_MAX_SECONDS=9000
# Discord map-event alerts (defaults to same as team chat; set false to disable Discord only)
AUTOMATION_EVENT_DISCORD=true
# Comma-separated: cargo, chinook, heli (default: all three)
AUTOMATION_EVENT_TYPES=cargo,chinook,heli
AUTOMATION_EVENT_TEAM_CHAT_PREFIX=RustTools

# --- Rust+ FCM (master bot pairing only) ---
# One fcm-config.json for the 24/7 bot account — NOT per-teammate companion links.
# Register: npx @liamcottle/rustplus.js fcm-register --config-file=./data/fcm-config.json
# Teammates link Steam ID and optional companion credentials in Settings → Account (no server FCM).
RUSTPLUS_FCM_CONFIG_PATH=./data/fcm-config.json
# Production: server pairs require admin to start Master Bot Server Pair first.
# Dev default is true; set false to test gated pairing locally.
# RUSTPLUS_ALLOW_UNPROMPTED_PAIR=false

# --- Caddy (reverse proxy) ---
DOMAIN=rusttools.yourdomain.com
ACME_EMAIL=you@example.com
