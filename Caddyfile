{$DOMAIN} {
	email {$ACME_EMAIL}
	encode gzip

	@api path /admin/* /audit /auth/* /automation-* /cameras/* /device-library* /devices* /health /push/* /servers* /storage* /switch-groups* /vending/* /ws
	handle @api {
		reverse_proxy api:3000
	}

	handle {
		respond "RustTools API — use the GitHub Pages frontend." 200
	}
}

:80 {
	respond "RustTools — set DOMAIN in .env for HTTPS." 200
}
