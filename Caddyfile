#
# Split-domain example (matthewgtran.com):
#   WEB_DOMAIN=rusttools.matthewgtran.com      → React dashboard (static files)
#   DOMAIN=rusttools-api.matthewgtran.com      → API + WebSocket + OAuth callback
#
# API-only (GitHub Pages UI): leave WEB_DOMAIN unset; DOMAIN = API hostname.

{$WEB_DOMAIN} {
	email {$ACME_EMAIL}
	encode gzip
	root * /srv/web
	try_files {path} /index.html
	file_server
}

{$DOMAIN} {
	email {$ACME_EMAIL}
	encode gzip
	reverse_proxy api:3000
}

:80 {
	respond "RustTools — run ./scripts/render-caddyfile.sh after editing .env" 200
